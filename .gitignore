# Dependencies
node_modules/

# Build output — dist/ is intentionally COMMITTED so `npm install -g git+https://…`
# works without a build step (npm's git-dep prepare is unreliable on Windows).
# Run `npm run build` and commit dist/ whenever src/ changes.

# Local overrides / secrets
*.local
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
