# Optional: override the default Pulse base URL (default: http://localhost:3000)
# Set this to your deployed Pulse instance URL (e.g. Railway URL)
PULSE_BASE_URL=http://localhost:3000

# Optional: override where the session/config is stored (default: ~/.pulse-cli).
# Use this to run isolated installs side by side — e.g. a local-dev "admin"
# session and a live "as me" session that never share cookies or base URL.
# PULSE_CONFIG_DIR=C:\Workspace\Tools\pulsecli\state
